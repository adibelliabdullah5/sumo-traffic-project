    <connection from="B_W2B" to="B2B_S"/>
    <connection from="B_W2B" to="B2A"/>   <!-- EKLENDİ -->

    <!-- East giriş -->
    <connection from="B_E2B" to="B2B_W"/>
    <connection from="B_E2B" to="B2B_N"/>
    <connection from="B_E2B" to="B2B_S"/>
    <connection from="B_E2B" to="B2A"/>   <!-- EKLENDİ -->

    <!-- North giriş -->
    <connection from="B_N2B" to="B2B_S"/>
    <connection from="B_N2B" to="B2B_E"/>
    <connection from="B_N2B" to="B2B_W"/>
    <connection from="B_N2B" to="B2A"/>   <!-- EKLENDİ -->

    <!-- South giriş -->
    <connection from="B_S2B" to="B2B_N"/>
    <connection from="B_S2B" to="B2B_E"/>
    <connection from="B_S2B" to="B2B_W"/>
    <connection from="B_S2B" to="B2A"/>   <!-- EKLENDİ -->

</connections>
