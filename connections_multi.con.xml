<connections>

    <!-- ===== JUNCTION A ===== -->

    <!-- West giriş -->
    <connection from="A_W2A" to="A2A_E"/>
    <connection from="A_W2A" to="A2A_N"/>
    <connection from="A_W2A" to="A2A_S"/>
    <connection from="A_W2A" to="A2B"/>   <!-- EKLENDİ -->

    <!-- East giriş -->
    <connection from="A_E2A" to="A2A_W"/>
    <connection from="A_E2A" to="A2A_N"/>
    <connection from="A_E2A" to="A2A_S"/>
    <connection from="A_E2A" to="A2B"/>   <!-- EKLENDİ -->

    <!-- North giriş -->
    <connection from="A_N2A" to="A2A_S"/>
