    <connection from="A_S2A" to="A2A_W"/>
    <connection from="A_S2A" to="A2B"/>   <!-- EKLENDİ -->

    <!-- B'den A'ya gelen -->
    <connection from="B2A" to="A2A_N"/>
    <connection from="B2A" to="A2A_S"/>
    <connection from="B2A" to="A2A_E"/>
    <connection from="B2A" to="A2A_W"/>


    <!-- ===== JUNCTION B ===== -->

    <!-- A'dan B'ye gelen yol (A2B) B kavşağına giriyor, B'den dağıt -->
    <connection from="A2B" to="B2B_N"/>
    <connection from="A2B" to="B2B_S"/>
    <connection from="A2B" to="B2B_E"/>
    <connection from="A2B" to="B2B_W"/>

    <!-- West giriş -->
    <connection from="B_W2B" to="B2B_E"/>
